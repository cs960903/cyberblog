---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到 | CyberBlog">
  <section class="not-found">
    <div class="container">
      <h1 class="neon-text">404</h1>
      <p>页面穿越到了未知的数据空间。</p>
      <a href={`${import.meta.env.BASE_URL}/`} style="display: inline-block; margin-top: 1.5rem; border: 1px solid var(--neon-cyan); padding: 0.6rem 1.5rem; border-radius: 8px; color: var(--neon-cyan);">← 回到首页</a>
    </div>
  </section>
</BaseLayout>
