<!-- 
  ⚠️ 使用前配置步骤：
  1. 在你的 GitHub 仓库启用 Discussions 功能（Settings → General → Discussions）
  2. 安装 Giscus App（https://github.com/apps/giscus）
  3. 打开 https://giscus.app 生成你的 data-repo / data-repo-id 等
  4. 将下方属性替换为实际值
-->
<!-- Giscus 评论组件 — 基于 GitHub Discussions -->
<script is:inline
  src="https://giscus.app/client.js"
  data-repo="你的GitHub用户名/你的仓库名"
  data-repo-id="R_kgDO..."
  data-category="Announcements"
  data-category-id="DIC_kwDO..."
  data-mapping="pathname"
  data-strict="0"
  data-reactions-enabled="1"
  data-emit-metadata="0"
  data-input-position="bottom"
  data-theme="dark"
  data-lang="zh-CN"
  async>
</script>
